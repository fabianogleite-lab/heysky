    var fatorCusto = t === 'comercial' ? 38 : t === 'rural' ? 32 : 42;
    var eco = conta * reducao;
    var ecoAnual = eco * 12;
    var custo = Math.max(conta * fatorCusto, 12000);
    var payback = custo / ecoAnual;
    var co2 = Math.round((conta / 0.80) * 0.000507 * 12 * 1000) / 1000;
    return { eco: eco, ecoAnual: ecoAnual, payback: payback, co2: co2, custo: custo };
  }

  btn.addEventListener('click', function() {
    var conta = parseFloat(inp.value) || 400;
    if (conta < 100) { conta = 100; inp.value = conta; }
    var r = calcular(conta);
    document.getElementById('eco-mensal').textContent = fmt(r.eco);
    document.getElementById('eco-anual').textContent = fmt(r.ecoAnual);
    document.getElementById('payback-anos').textContent = r.payback.toFixed(1) + ' anos';
    document.getElementById('co2-evitado').textContent = r.co2.toFixed(1) + ' t';
    results.classList.add('show');
    var msg = 'Quero+orçamento+solar:+conta+de+R$+' + Math.round(conta) + ',+economia+estimada+R$+' + Math.round(r.eco) + '/mês';
    waBtn.href = 'https://wa.me/5531983140497?text=' + msg;
    results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  inp.addEventListener('keydown', function(e) { if (e.key === 'Enter') btn.click(); });
})();

// ── SECTION TRACKER (dwell time) ──
const _sections = ['hero','numeros','como-funciona','sistemas','retorno','beneficios','faq'];
const _times = {}, _starts = {};
const _trackObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    const id = e.target.dataset.section || e.target.id;
    if (!id) return;
    if (e.isIntersecting) { _starts[id] = Date.now(); }
    else if (_starts[id]) { _times[id] = (_times[id]||0) + Date.now() - _starts[id]; delete _starts[id]; }
  });
}, { threshold: 0.3 });
document.querySelectorAll('[data-section]').forEach(el => _trackObs.observe(el));
window.getProteOSContext = () => {
  Object.keys(_starts).forEach(id => { _times[id] = (_times[id]||0) + Date.now() - _starts[id]; });
  const sorted = Object.entries(_times).sort((a,b)=>b[1]-a[1]);
  const labels = { hero:'calculadora/início', numeros:'números/impacto', 'como-funciona':'instalação', sistemas:'tipo de sistema', retorno:'payback/retorno', beneficios:'benefícios', faq:'dúvidas' };
  return { topInterest: sorted[0] ? labels[sorted[0][0]] || sorted[0][0] : null, topInterestMs: sorted[0] ? sorted[0][1] : 0, all: sorted.map(([k,v])=>({ section: labels[k]||k, seconds: Math.round(v/1000) })) };
};

// ── PAYBACK BARS ANIMATE ON VISIBLE ──
const pbObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      document.getElementById('pb-retorno').style.width = '22%';
      document.getElementById('pb-energia').style.width = '88%';
      document.getElementById('pb-val').style.width = '55%';
      pbObs.disconnect();
    }
  });
}, { threshold: 0.4 });
const retornoEl = document.getElementById('retorno');
if (retornoEl) pbObs.observe(retornoEl);

// ── FAQ ACCORDION ──
document.querySelectorAll('.faq-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item');
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(i => { i.classList.remove('open'); i.querySelector('.faq-btn').setAttribute('aria-expanded','false'); });
    if (!isOpen) { item.classList.add('open'); btn.setAttribute('aria-expanded','true'); }
  });
});

// ── PROTEОS SIDEBAR ──
(function() {
  var sb = document.getElementById('proteOS-sidebar');
  var tab = document.getElementById('sidebar-tab');
  var closeBtn = document.getElementById('sb-close');
  var msgs = document.getElementById('sb-msgs');
  var input = document.getElementById('sb-input');
  var send = document.getElementById('sb-send');
  var sbCalcInp = document.getElementById('sb-calc-inp');
  var sbCalcGo = document.getElementById('sb-calc-go');
  var sbCalcResult = document.getElementById('sb-calc-result');

  function openSB()  { sb.classList.add('open'); }
  function closeSB() { sb.classList.remove('open'); }
  tab.addEventListener('click', () => sb.classList.contains('open') ? closeSB() : openSB());
  closeBtn.addEventListener('click', closeSB);

  // Mini calculadora na sidebar
  sbCalcGo.addEventListener('click', function() {
    var v = parseFloat(sbCalcInp.value) || 400;
    var eco = Math.round(v * 0.92);
    sbCalcResult.textContent = '💰 Economia estimada: R$ ' + eco.toLocaleString('pt-BR') + '/mês';
    sbCalcResult.style.display = 'block';
  });

  var R = {
    conta: { r: 'Para uma conta de R$ {v}, a economia estimada é R$ {eco}/mês. O payback fica em torno de {pb} anos. Quer receber uma proposta detalhada?', wa: 'Conta+de+R$+{v},+quero+proposta+de+solar' },
    financiamento: { r: 'Financiamos em até 120x sem entrada. As parcelas ficam geralmente abaixo da sua conta atual. Aprovação em 24h. Quer simular?', wa: 'Quero+saber+sobre+financiamento+solar' },
    tempo: { r: 'A instalação física leva 1–2 dias. A conexão à CEMIG leva 30–90 dias. A geração começa no dia da instalação!', wa: 'Prazo+de+instalação+solar' },
    manutenção: { r: 'Manutenção mínima: limpeza 1–2x por ano. Painéis com 25 anos de garantia. Zero peças móveis.', wa: 'Manutenção+sistema+solar' },
    default_: { r: 'Entendido! Para te ajudar melhor, qual é o valor médio da sua conta de luz?', wa: 'Quero+informações+sobre+energia+solar' }
  };

  function addMsg(text, type, ctaLink) {
    var d = document.createElement('div');
    d.className = 'sb-msg ' + type;
    d.textContent = text;
    if (ctaLink) {
      var a = document.createElement('a');
      a.className = 'sb-msg-cta'; a.href = ctaLink; a.target = '_blank'; a.rel = 'noopener';
      a.textContent = '💬 Continuar no WhatsApp →';
      d.appendChild(document.createElement('br'));
      d.appendChild(a);
    }
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
    return d;
  }

  function botRespond(userText) {
    var t = userText.toLowerCase();
    var typing = addMsg('ProteOS está calculando...', 'sb-msg bot');
    var r = R.default_;
    var wa = 'Quero+informações+sobre+energia+solar';
    var num = parseFloat(t.replace(/[^0-9,.]/g,'').replace(',','.'));

    if (!isNaN(num) && num >= 100) {
      var eco = Math.round(num * 0.92);
      var pb = (num * 20 / (eco * 12)).toFixed(1);
      var resp = R.conta.r.replace('{v}', Math.round(num).toLocaleString('pt-BR')).replace('{eco}', eco.toLocaleString('pt-BR')).replace('{pb}', pb);
      var waLink = 'https://wa.me/5531983140497?text=' + R.conta.wa.replace('{v}', Math.round(num));
      setTimeout(function() { typing.remove(); addMsg(resp, 'bot', waLink); }, 1200);
      return;
    }
    if (/financ|parcel|entrada|crédito|créd/i.test(t)) r = R.financiamento;
    else if (/tempo|prazo|quantos dias|quando/i.test(t)) r = R.tempo;
    else if (/manut|limpe|garanti/i.test(t)) r = R.manutenção;
    else {
      var ctx = window.getProteOSContext ? window.getProteOSContext() : null;
      var top = ctx && ctx.topInterest;
      if (top && top !== 'calculadora/início') {
        r = { r: 'Vi que você estava vendo ' + top + '. Posso detalhar esse ponto. Qual o valor da sua conta de luz?', wa: 'Dúvida+sobre+' + encodeURIComponent(top) };
      }
    }
    setTimeout(function() {
      typing.remove();
      addMsg(r.r, 'bot', 'https://wa.me/5531983140497?text=' + r.wa);
    }, 1200 + Math.random() * 500);
  }

  function sendMsg() {
    var v = input.value.trim();
    if (!v) return;
    addMsg(v, 'user');
    input.value = '';
    botRespond(v);
  }

  send.addEventListener('click', sendMsg);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg(); });
  setTimeout(() => { if (!sb.classList.contains('open')) openSB(); }, 90000);
})();

// ── SMART CTA ──
(function() {
  var cta = document.getElementById('smart-cta');
  var btn = document.getElementById('scta-btn');
  var title = document.getElementById('scta-msg-title');
  var body = document.getElementById('scta-msg-body');
  var closeBtn = document.getElementById('scta-close');
  var dismissed = false;
  closeBtn.addEventListener('click', () => { dismissed = true; cta.classList.remove('visible'); });

  var CTX = {
    hero: { t: 'Calcule sua economia agora', b: 'Simulação gratuita, sem compromisso.', wa: 'Quero+simulação+de+economia+solar' },
    'como-funciona': { t: 'Instalação em 2 dias', b: 'Orçamento grátis, aprovação em 24h.', wa: 'Quero+orçamento+instalação+solar' },
    sistemas: { t: 'Qual sistema é ideal para você?', b: 'Residencial, comercial ou rural — simulamos agora.', wa: 'Qual+sistema+solar+é+ideal+para+mim' },
    retorno: { t: 'Seu dinheiro trabalhando por você', b: 'Payback de 4–6 anos. 25 anos de lucro.', wa: 'Quero+calcular+o+retorno+do+solar' },
    faq: { t: 'Ficou com dúvida?', b: 'Falo com você agora no WhatsApp.', wa: 'Tenho+dúvidas+sobre+energia+solar' },
  };

  var current = 'hero';
  var HIGH = new Set(['sistemas','retorno','faq']);
  var startTime = Date.now();
  var shown = false;

  var secObs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) current = e.target.dataset.section || e.target.id; });
  }, { threshold: 0.4 });
  document.querySelectorAll('[data-section]').forEach(el => secObs.observe(el));

  function show() {
    if (dismissed || shown) return;
    var ctx = CTX[current] || CTX.hero;
    title.textContent = ctx.t;
    body.textContent = ctx.b;
    btn.href = 'https://wa.me/5531983140497?text=' + ctx.wa;
    cta.classList.add('visible');
    shown = true;
    setTimeout(() => { cta.classList.remove('visible'); }, 10000);
  }

  setTimeout(() => { if (!shown) show(); }, 45000);
  setTimeout(() => { if (HIGH.has(current) && !shown) show(); }, 25000);
  window.addEventListener('scroll', function() {
    var pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
    if (pct > 0.7 && Date.now() - startTime > 30000 && !shown) show();
  }, { passive: true });
})();
</script>

